<Window x:Class="MovieApp.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:MovieApp.UI.Views"
        mc:Ignorable="d"
        Title="MovieApp"
        Width="1480"
        Height="920"
        MinWidth="1200"
        MinHeight="760"
        WindowStartupLocation="CenterScreen"
        Background="#F7F1E8">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Margin="0,0,0,14">
            <TextBlock FontSize="30"
                       FontWeight="Bold"
                       Foreground="#1E293B"
                       Text="MovieApp" />
            <TextBlock Margin="0,6,0,0"
                       Foreground="#475569"
                       Text="Catalog, reviews, battles, discussions, points, and badges in one desktop workspace." />
        </StackPanel>

        <TabControl Grid.Row="1"
                    Background="#FFFDF9"
                    BorderBrush="#D9C7A0"
                    SelectedIndex="{Binding SelectedTabIndex}">
            <TabItem Header="Catalog">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2.3*" />
                        <ColumnDefinition Width="3*" />
                    </Grid.ColumnDefinitions>

                    <views:CatalogView DataContext="{Binding CatalogViewModel}" />

                    <Grid Grid.Column="1" Margin="18,0,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="3.2*" />
                            <RowDefinition Height="2*" />
                        </Grid.RowDefinitions>

                        <views:MovieDetailView DataContext="{Binding MovieDetailViewModel}" />
                        <views:ForumView Grid.Row="1" Margin="0,18,0,0" DataContext="{Binding ForumViewModel}" />
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Header="Battle Arena">
                <views:BattleView Margin="10" DataContext="{Binding BattleViewModel}" />
            </TabItem>

            <TabItem Header="Forum">
                <views:ForumView Margin="10" DataContext="{Binding ForumViewModel}" />
            </TabItem>

            <TabItem Header="Points &amp; Badges">
                <views:ProfileView Margin="10" DataContext="{Binding ProfileViewModel}" />
            </TabItem>
        </TabControl>
    </Grid>
</Window>

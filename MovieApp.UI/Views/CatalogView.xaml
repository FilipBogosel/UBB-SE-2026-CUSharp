<UserControl x:Class="MovieApp.UI.Views.CatalogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Border Padding="16"
            Background="#FFF9F1"
            BorderBrush="#E7D7B6"
            BorderThickness="1"
            CornerRadius="16">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel>
                <TextBlock FontSize="24"
                           FontWeight="Bold"
                           Foreground="#1F2937"
                           Text="Catalog" />
                <TextBlock Margin="0,4,0,0"
                           Foreground="#6B7280"
                           Text="{Binding StatusMessage}" />
            </StackPanel>

            <Grid Grid.Row="1" Margin="0,16,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="1.1*" />
                    <ColumnDefinition Width="1.2*" />
                </Grid.ColumnDefinitions>

                <StackPanel Margin="0,0,12,0">
                    <TextBlock FontWeight="SemiBold" Text="Search title" />
                    <TextBox Margin="0,6,0,0"
                             Padding="10"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="0,0,12,0">
                    <TextBlock FontWeight="SemiBold" Text="Genre" />
                    <ComboBox Margin="0,6,0,0"
                              Padding="8"
                              ItemsSource="{Binding Genres}"
                              SelectedItem="{Binding SelectedGenre}" />
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock FontWeight="SemiBold" Text="Minimum rating" />
                    <Slider Margin="0,10,0,0"
                            Minimum="0"
                            Maximum="5"
                            TickFrequency="0.5"
                            IsSnapToTickEnabled="True"
                            Value="{Binding MinimumRating}" />
                    <TextBlock HorizontalAlignment="Right"
                               Foreground="#92400E"
                               Text="{Binding MinimumRating, StringFormat=F1}" />
                </StackPanel>
            </Grid>

            <ListView Grid.Row="2"
                      Background="Transparent"
                      BorderThickness="0"
                      ItemsSource="{Binding Movies}"
                      SelectedItem="{Binding SelectedMovie}">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,0,12"
                                Padding="12"
                                Background="#FFFDF9"
                                BorderBrush="#E7D7B6"
                                BorderThickness="1"
                                CornerRadius="14">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="90" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border Width="72"
                                        Height="108"
                                        CornerRadius="12"
                                        Background="#E5E7EB"
                                        ClipToBounds="True">
                                    <Image Source="{Binding PosterUrl}" Stretch="Fill" />
                                </Border>

                                <StackPanel Grid.Column="1" Margin="14,0,0,0">
                                    <TextBlock FontSize="18"
                                               FontWeight="Bold"
                                               Foreground="#1F2937"
                                               Text="{Binding Title}" />
                                    <TextBlock Margin="0,6,0,0"
                                               Foreground="#6B7280"
                                               Text="{Binding Year}" />
                                    <TextBlock Margin="0,10,0,0"
                                               Foreground="#92400E"
                                               Text="{Binding Genre}" />
                                    <TextBlock Margin="0,8,0,0"
                                               FontWeight="SemiBold"
                                               Foreground="#0F766E"
                                               Text="{Binding AverageRating, StringFormat=Average rating: {0:F1}}" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>
    </Border>
</UserControl>

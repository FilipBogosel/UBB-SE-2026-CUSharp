<UserControl x:Class="MovieApp.UI.Views.MovieDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </UserControl.Resources>
    <Border Padding="16"
            Background="#FFF9F1"
            BorderBrush="#E7D7B6"
            BorderThickness="1"
            CornerRadius="16">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock FontSize="24"
                           FontWeight="Bold"
                           Foreground="#1F2937"
                           Text="{Binding CurrentMovie.Title, TargetNullValue=Movie details}" />
                <TextBlock Margin="0,4,0,0"
                           Foreground="#6B7280"
                           Text="{Binding StatusMessage}" />

                <Grid Margin="0,18,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="190" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Width="170"
                            Height="250"
                            Background="#E5E7EB"
                            CornerRadius="16"
                            ClipToBounds="True">
                        <Image Source="{Binding CurrentMovie.PosterUrl}" Stretch="Fill" />
                    </Border>

                    <StackPanel Grid.Column="1" Margin="18,0,0,0">
                        <TextBlock FontSize="18"
                                   FontWeight="SemiBold"
                                   Text="{Binding CurrentMovie.Year, StringFormat=Release year: {0}}" />
                        <TextBlock Margin="0,10,0,0"
                                   FontSize="16"
                                   Foreground="#92400E"
                                   Text="{Binding CurrentMovie.Genre, StringFormat=Genre: {0}}" />
                        <TextBlock Margin="0,10,0,0"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="#0F766E"
                                   Text="{Binding CurrentMovie.AverageRating, StringFormat=Average rating: {0:F1}}" />
                        <TextBlock Margin="0,20,0,0"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Text="Add Review" />
                        <TextBlock Margin="0,12,0,0" FontWeight="SemiBold" Text="Star rating" />
                        <ComboBox Margin="0,6,0,0"
                                  Width="140"
                                  ItemsSource="{Binding RatingOptions}"
                                  SelectedItem="{Binding SelectedRating}" />
                        <TextBlock Margin="0,12,0,0" FontWeight="SemiBold" Text="Review text" />
                        <TextBox Margin="0,6,0,0"
                                 Height="90"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 Text="{Binding ReviewContent, UpdateSourceTrigger=PropertyChanged}" />
                        <Button Margin="0,12,0,0"
                                Padding="14,10"
                                HorizontalAlignment="Left"
                                Background="#C2410C"
                                BorderThickness="0"
                                Command="{Binding SubmitReviewCommand}"
                                Content="Submit Review"
                                Foreground="White" />
                        <Button Margin="0,12,0,0"
                                Padding="14,10"
                                HorizontalAlignment="Left"
                                Background="#1D4ED8"
                                BorderThickness="0"
                                Command="{Binding ToggleExtraReviewCommand}"
                                Content="Add Extra Review"
                                Foreground="White"
                                Visibility="{Binding HasUserReview, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    </StackPanel>
                </Grid>

                <Border Margin="0,18,0,0"
                        Padding="16"
                        Background="#FFFDF9"
                        BorderBrush="#E7D7B6"
                        BorderThickness="1"
                        CornerRadius="14"
                        Visibility="{Binding IsExtraReviewExpanded, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel>
                        <TextBlock FontSize="18"
                                   FontWeight="Bold"
                                   Text="Extended review" />
                        <TextBlock Margin="0,12,0,0" FontWeight="SemiBold" Text="Main extra review" />
                        <TextBox Margin="0,6,0,0"
                                 Height="110"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 Text="{Binding ExtraReviewContent, UpdateSourceTrigger=PropertyChanged}" />

                        <UniformGrid Margin="0,16,0,0" Columns="2">
                            <StackPanel Margin="0,0,12,12">
                                <TextBlock FontWeight="SemiBold" Text="Cinematography" />
                                <ComboBox Margin="0,6,0,0" ItemsSource="{Binding RatingOptions}" SelectedItem="{Binding SelectedCinematographyRating}" />
                                <TextBox Margin="0,6,0,0" Height="80" AcceptsReturn="True" TextWrapping="Wrap" Text="{Binding CinematographyText, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Margin="12,0,0,12">
                                <TextBlock FontWeight="SemiBold" Text="Acting" />
                                <ComboBox Margin="0,6,0,0" ItemsSource="{Binding RatingOptions}" SelectedItem="{Binding SelectedActingRating}" />
                                <TextBox Margin="0,6,0,0" Height="80" AcceptsReturn="True" TextWrapping="Wrap" Text="{Binding ActingText, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Margin="0,0,12,12">
                                <TextBlock FontWeight="SemiBold" Text="CGI" />
                                <ComboBox Margin="0,6,0,0" ItemsSource="{Binding RatingOptions}" SelectedItem="{Binding SelectedCgiRating}" />
                                <TextBox Margin="0,6,0,0" Height="80" AcceptsReturn="True" TextWrapping="Wrap" Text="{Binding CgiText, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Margin="12,0,0,12">
                                <TextBlock FontWeight="SemiBold" Text="Plot" />
                                <ComboBox Margin="0,6,0,0" ItemsSource="{Binding RatingOptions}" SelectedItem="{Binding SelectedPlotRating}" />
                                <TextBox Margin="0,6,0,0" Height="80" AcceptsReturn="True" TextWrapping="Wrap" Text="{Binding PlotText, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Margin="0,0,12,0">
                                <TextBlock FontWeight="SemiBold" Text="Sound / Music" />
                                <ComboBox Margin="0,6,0,0" ItemsSource="{Binding RatingOptions}" SelectedItem="{Binding SelectedSoundRating}" />
                                <TextBox Margin="0,6,0,0" Height="80" AcceptsReturn="True" TextWrapping="Wrap" Text="{Binding SoundText, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </UniformGrid>

                        <Button Margin="0,8,0,0"
                                Padding="14,10"
                                HorizontalAlignment="Left"
                                Background="#0F766E"
                                BorderThickness="0"
                                Command="{Binding SubmitExtraReviewCommand}"
                                Content="Submit Extra Review"
                                Foreground="White" />
                    </StackPanel>
                </Border>

                <Grid Margin="0,18,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.3*" />
                        <ColumnDefinition Width="1*" />
                    </Grid.ColumnDefinitions>

                    <Border Padding="16"
                            Background="#FFFDF9"
                            BorderBrush="#E7D7B6"
                            BorderThickness="1"
                            CornerRadius="14">
                        <StackPanel>
                            <TextBlock FontSize="18"
                                       FontWeight="Bold"
                                       Text="Internal Reviews" />
                            <ItemsControl Margin="0,12,0,0" ItemsSource="{Binding Reviews}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,10"
                                                Padding="12"
                                                Background="#FFFBF5"
                                                BorderBrush="#F1E4C8"
                                                BorderThickness="1"
                                                CornerRadius="12">
                                            <StackPanel>
                                                <TextBlock FontWeight="Bold"
                                                           Text="{Binding StarRating, StringFormat=Rating: {0:F1}}" />
                                                <TextBlock Margin="0,4,0,0"
                                                           Foreground="#6B7280"
                                                           Text="{Binding CreatedAt, StringFormat={}{0:g}}" />
                                                <TextBlock Margin="0,8,0,0"
                                                           TextWrapping="Wrap"
                                                           Text="{Binding Content}" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1"
                            Margin="18,0,0,0"
                            Padding="16"
                            Background="#FFFDF9"
                            BorderBrush="#E7D7B6"
                            BorderThickness="1"
                            CornerRadius="14">
                        <StackPanel>
                            <TextBlock FontSize="18"
                                       FontWeight="Bold"
                                       Text="External Reviews" />
                            <TextBlock Margin="0,12,0,0"
                                       FontWeight="SemiBold"
                                       Foreground="#0F766E"
                                       Text="{Binding CriticScore, StringFormat=Critic score: {0:F1}}" />
                            <TextBlock Margin="0,4,0,0"
                                       FontWeight="SemiBold"
                                       Foreground="#92400E"
                                       Text="{Binding AudienceScore, StringFormat=Audience score: {0:F1}}" />
                            <TextBlock Margin="0,10,0,0"
                                       FontWeight="SemiBold"
                                       Foreground="#B91C1C"
                                       Text="Polarized reception"
                                       Visibility="{Binding IsPolarized, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            <TextBlock Margin="0,10,0,0"
                                       Foreground="#6B7280"
                                       Text="Loading..."
                                       Visibility="{Binding IsLoadingExternalData, Converter={StaticResource BooleanToVisibilityConverter}}" />

                            <TextBlock Margin="0,16,0,0"
                                       FontWeight="Bold"
                                       Text="Critic snippets" />
                            <ItemsControl Margin="0,10,0,0" ItemsSource="{Binding CriticReviews}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,10"
                                                Padding="12"
                                                Background="#FFFBF5"
                                                BorderBrush="#F1E4C8"
                                                BorderThickness="1"
                                                CornerRadius="12">
                                            <StackPanel>
                                                <TextBlock FontWeight="Bold"
                                                           Text="{Binding Source}" />
                                                <TextBlock Margin="0,4,0,0"
                                                           FontWeight="SemiBold"
                                                           Text="{Binding Headline}" />
                                                <TextBlock Margin="0,6,0,0"
                                                           TextWrapping="Wrap"
                                                           Text="{Binding Snippet}" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <TextBlock Margin="0,8,0,0"
                                       FontWeight="Bold"
                                       Text="Lexicon words" />
                            <ItemsControl Margin="0,8,0,0" ItemsSource="{Binding LexiconWords}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Margin="0,0,0,4" Text="{Binding Display}" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </Border>
</UserControl>

<UserControl x:Class="MovieApp.UI.Views.ProfileView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <UserControl.Resources>
        <Style x:Key="BadgeCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#FFFBF5" />
            <Setter Property="BorderBrush" Value="#F1E4C8" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsUnlocked}" Value="True">
                    <Setter Property="Background" Value="#ECFDF5" />
                    <Setter Property="BorderBrush" Value="#A7F3D0" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="BadgeStatusStyle" TargetType="Border">
            <Setter Property="Background" Value="#E5E7EB" />
            <Setter Property="CornerRadius" Value="12" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsUnlocked}" Value="True">
                    <Setter Property="Background" Value="#BBF7D0" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>
    <Border Padding="18"
            Background="#FFF9F1"
            BorderBrush="#E7D7B6"
            BorderThickness="1"
            CornerRadius="16">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock FontSize="24"
                               FontWeight="Bold"
                               Foreground="#1F2937"
                               Text="Points &amp; Badges" />
                    <TextBlock Margin="0,4,0,0"
                               Foreground="#6B7280"
                               Text="{Binding StatusMessage}" />
                </StackPanel>

                <UniformGrid Grid.Row="1" Margin="0,18,0,18" Columns="3">
                    <Border Margin="0,0,12,0"
                            Padding="16"
                            Background="#FFFDF9"
                            BorderBrush="#E7D7B6"
                            BorderThickness="1"
                            CornerRadius="14">
                        <StackPanel>
                            <TextBlock FontWeight="Bold" Text="Total Points" />
                            <TextBlock Margin="0,10,0,0"
                                       FontSize="28"
                                       FontWeight="Bold"
                                       Foreground="#0F766E"
                                       Text="{Binding TotalPoints}" />
                        </StackPanel>
                    </Border>

                    <Border Margin="6,0"
                            Padding="16"
                            Background="#FFFDF9"
                            BorderBrush="#E7D7B6"
                            BorderThickness="1"
                            CornerRadius="14">
                        <StackPanel>
                            <TextBlock FontWeight="Bold" Text="Weekly Score" />
                            <TextBlock Margin="0,10,0,0"
                                       FontSize="28"
                                       FontWeight="Bold"
                                       Foreground="#92400E"
                                       Text="{Binding WeeklyScore}" />
                        </StackPanel>
                    </Border>

                    <Border Margin="12,0,0,0"
                            Padding="16"
                            Background="#FFFDF9"
                            BorderBrush="#E7D7B6"
                            BorderThickness="1"
                            CornerRadius="14">
                        <StackPanel>
                            <TextBlock FontWeight="Bold" Text="Unlocked Badges" />
                            <TextBlock Margin="0,10,0,0"
                                       FontSize="28"
                                       FontWeight="Bold"
                                       Foreground="#7C3AED"
                                       Text="{Binding EarnedBadgeCount}" />
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <Border Grid.Row="2"
                        Padding="16"
                        Background="#FFFDF9"
                        BorderBrush="#E7D7B6"
                        BorderThickness="1"
                        CornerRadius="14">
                    <StackPanel>
                        <TextBlock FontSize="18"
                                   FontWeight="Bold"
                                   Text="Badge Cabinet" />

                        <ItemsControl Margin="0,14,0,0" ItemsSource="{Binding Badges}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,10"
                                            Padding="14"
                                            Style="{StaticResource BadgeCardStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <StackPanel>
                                                <TextBlock FontWeight="Bold"
                                                           Foreground="#1F2937"
                                                           Text="{Binding Name}" />
                                                <TextBlock Margin="0,4,0,0"
                                                           Foreground="#6B7280"
                                                           Text="{Binding RequirementText}" />
                                                <TextBlock Margin="0,6,0,0"
                                                           FontWeight="SemiBold"
                                                           Foreground="#92400E"
                                                           Text="{Binding ProgressText}" />
                                            </StackPanel>

                                            <Border Grid.Column="1"
                                                    Padding="10,6"
                                                    Style="{StaticResource BadgeStatusStyle}">
                                                <TextBlock Text="{Binding StatusLabel}" />
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </Grid>
        </ScrollViewer>
    </Border>
</UserControl>
